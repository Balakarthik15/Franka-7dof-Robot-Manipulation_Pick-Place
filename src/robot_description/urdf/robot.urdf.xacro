<?xml version="1.0" ?>
<robot name="Franka_Panda" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find robot_description)/urdf/arm.xacro"/>
    <xacro:include filename="$(find robot_controllers)/urdf/ros2_control.xacro" />
    <xacro:include filename="$(find robot_description)/urdf/gazebo.xacro"/>
</robot>
